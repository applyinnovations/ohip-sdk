{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repository",
    "release",
    "ref",
    "commit",
    "specDirectory",
    "patches",
    "patchedFiles"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "repository": { "type": "string", "format": "uri" },
    "release": { "type": "string" },
    "ref": { "type": "string" },
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "specDirectory": { "type": "string" },
    "patches": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "patchedFiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9a-f]{64}$"
      }
    },
    "legacyFork": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit"],
      "properties": {
        "repository": { "type": "string", "format": "uri" },
        "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
      }
    }
  }
}
